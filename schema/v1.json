{
  "$id": "https://raw.githubusercontent.com/ginden/timertab/v1.0.0/schema/v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "timertab v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "jobs"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "const": 1
    },
    "jobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/job"
      },
      "default": []
    }
  },
  "$defs": {
    "env": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "schedule": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:@(?:hourly|daily|weekly|monthly|yearly|annually|reboot)|\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+)$"
    },
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "$ref": "#/$defs/env"
        }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "when",
        "run"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "when": {
          "oneOf": [
            {
              "$ref": "#/$defs/schedule"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/schedule"
              }
            }
          ]
        },
        "run": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "$ref": "#/$defs/env"
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "persistent": {
          "type": "boolean"
        },
        "on_success": {
          "$ref": "#/$defs/hook"
        },
        "on_failure": {
          "$ref": "#/$defs/hook"
        }
      }
    }
  }
}
