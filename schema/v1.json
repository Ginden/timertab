{
  "$id": "https://raw.githubusercontent.com/ginden/timertab/v1.1.0/schema/v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "timertab v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "jobs"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "const": 1
    },
    "instance_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto_commit": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "jobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/job"
      },
      "default": []
    }
  },
  "$defs": {
    "env": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "schedule": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:@(?:hourly|daily|weekly|monthly|yearly|annually|reboot)|\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+)$"
    },
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "$ref": "#/$defs/env"
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "MemoryMax": {
          "type": "string",
          "minLength": 1
        },
        "CPUQuota": {
          "type": "string",
          "minLength": 1
        },
        "IOWeight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        }
      }
    },
    "systemd_directive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "systemd_directive_set": {
      "oneOf": [
        {
          "type": "object",
          "propertyNames": {
            "minLength": 1
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/systemd_directive"
          }
        }
      ]
    },
    "systemd_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service": {
          "$ref": "#/$defs/systemd_directive_set"
        },
        "timer": {
          "$ref": "#/$defs/systemd_directive_set"
        }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "when",
        "run"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "when": {
          "oneOf": [
            {
              "$ref": "#/$defs/schedule"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/schedule"
              }
            }
          ]
        },
        "run": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "env": {
          "$ref": "#/$defs/env"
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "persistent": {
          "type": "boolean"
        },
        "jitter": {
          "type": "string",
          "minLength": 1
        },
        "limits": {
          "$ref": "#/$defs/limits"
        },
        "systemd": {
          "$ref": "#/$defs/systemd_overrides"
        },
        "on_success": {
          "$ref": "#/$defs/hook"
        },
        "on_failure": {
          "$ref": "#/$defs/hook"
        }
      }
    }
  }
}
